rules_version = '2';
// ══════════════════════════════════════════════════════════════
//  최종 배포용 "강한 규칙" — firestore.compat.rules(1차 호환 규칙) 다음 단계.
//
//  이 단계는 새 index.html이 이미 라이브에 올라가 있고(구버전 클라이언트가
//  더 이상 트래픽의 주력이 아닌 상태), Phase A/B로 평문 PIN 스크럽까지 끝난
//  뒤에만 배포한다. 이 규칙을 compat 단계에서 너무 일찍 걸면, 구버전
//  클라이언트의 "스킨 최초구매(한 번의 쓰기에 skin+ownedSkins를 같이 저장)"
//  같은 정상 흐름이 깨진다.
//
//  compat 대비 추가된 것:
//  ① rankings — pin/delpin 필드를 그 어떤 클라이언트도 다시 쓸 수 없음
//     (noPinFields). 평문 PIN 재유입을 규칙 레벨에서 원천 차단.
//  ② rankings — 닉네임 변경 시 "옛 닉네임 문서 삭제"를 uid 소유자 본인이
//     직접 할 수 있도록 delete 권한 추가 (서버 함수 없이도 정상 동작하게).
//  ③ user_stats — 젤리는 클라이언트가 절대 늘릴 수 없음(감소·동일만).
//     증가(출석·구매)는 전부 서버 함수(shopAction)만.
//  ④ nickname_skins — cat(유료 고양이)·ownedSkins(소유 목록)·bubblePurchased
//     (말풍선 구매 상태)는 클라이언트가 절대 바꿀 수 없음(동일값 유지만).
//     장착 필드(skin)는 무료 컬러이거나 이미 ownedSkins에 있는 것만 허용
//     — 구매 안 한 유료 효과를 직접 setDoc으로 장착 불가.
//     frame은 여전히 어드민/서버 전용(변경 불가).
//
//  uidFieldOk()는 firestore.compat.rules에서 이미 검증된 수정판을 그대로 사용.
//  그 외 24개 컬렉션 구조는 compat과 동일.
// ══════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'dofesyOMISTSAKEKBEpqAyV2PTr2';
    }
    // 오너(오잉이)의 게임 계정 uid — 게임 안에서 문의·후원 쪽지 "읽기"만 허용한다.
    // isAdmin()의 전체 쓰기 권한(점수 조작·삭제 등)과 분리해, 딱 열람 권한만 준다.
    // Firebase 익명 인증 세션 기반이라 위조 불가(과거 localStorage 플래그 방식과 근본적으로 다름).
    function isOwnerDevice() {
      return request.auth != null
        && request.auth.uid == 'nCNTJnd5GmRlEbRu3e1xPWxB8Og2';
    }
    function signedIn() { return request.auth != null; }

    function validScore() {
      return request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 50000;
    }
    function validNick(nick) {
      return nick.size() >= 1 && nick.size() <= 20
        && !nick.matches('.*[<>].*');
    }
    function okStr(v, maxLen) {
      return v == null
        || (v is string && v.size() <= maxLen && !v.matches('.*[<>].*'));
    }
    function validLog() {
      return request.resource.data.keys().hasOnly(['nickname','ts','date'])
        && okStr(request.resource.data.get('nickname', ''), 20);
    }
    // ⭐ 리뷰 입구 버튼 클릭 — validLog()에 source(랭킹탭/메인 어디서 눌렀는지)만 추가한 변형
    function validReviewClickLog() {
      return request.resource.data.keys().hasOnly(['nickname','ts','date','source'])
        && okStr(request.resource.data.get('nickname', ''), 20)
        && request.resource.data.get('source', '') in ['rank', 'main', 'unknown'];
    }
    function isUidDoc(id) {
      return signedIn() && id == request.auth.uid;
    }

    // uid 소유권 검증 — compat 단계에서 검증된 수정판 그대로 사용.
    // (기존 문서에 uid가 있으면 그 소유자 본인만, 그리고 결과 문서에도
    //  uid가 그대로 남아있어야만 허용 — 삭제·변경·타인수정 전부 차단)
    // uid 소유권 검증 — 2차 수정판. 레거시 문서에 uid를 "최초 연결"하는 것은
    // 클라이언트가 할 수 없다 — 반드시 PIN 검증을 거친 서버(Admin SDK)만.
    // (1차 수정은 "로그인만 하면 자기 uid를 붙일 수 있음"을 허용해서, 남의
    //  미연결 레거시 문서를 먼저 가로채는 탈취 경로가 남아있었음 — 이제 제거)
    function uidFieldOk() {
      return (
        !('uid' in resource.data) && !('uid' in request.resource.data)
      ) || (
        ('uid' in resource.data)
        && signedIn()
        && resource.data.uid == request.auth.uid
        && ('uid' in request.resource.data)
        && request.resource.data.uid == resource.data.uid
      );
    }
    function uidFieldOkCreate() {
      return !('uid' in request.resource.data)
        || (signedIn() && request.resource.data.uid == request.auth.uid);
    }

    // ── 신규: 평문 PIN 완전 차단 ──
    // Phase B로 이미 스크럽된 뒤이므로, 이 시점부터는 어떤 클라이언트도
    // pin/delpin 필드를 다시 만들어낼 수 없다 (재유입 원천 차단).
    function noPinFields() {
      return !('pin' in request.resource.data) && !('delpin' in request.resource.data);
    }

    // rankings — pin/delpin 영구 차단 + uid 소유자 본인 삭제 허용
    // PR3: 공식 score 변경은 Cloud Function(Admin SDK, 규칙 우회)만.
    //  클라이언트가 허용되는 것은 (a) score:0 신규 등록 create, (b) score 불변 metadata/uid update,
    //  (c) owner delete 뿐. 게임 점수 반영은 전부 submitScore CF가 rankings/weekly를 atomic으로 갱신.
    match /rankings/{nick} {
      allow read: if true;
      // 신규 닉네임 등록만 클라 허용 — 반드시 score == 0 (실제 점수는 CF만 씀)
      allow create: if isAdmin()
        || (validNick(nick) && uidFieldOkCreate() && noPinFields()
            && request.resource.data.score == 0
            && request.resource.data.keys().hasOnly(['score','ts','uid']));
      // 클라 update는 score를 절대 바꿀 수 없음(불변). uid/ts 등 metadata만.
      allow update: if isAdmin()
        || (uidFieldOk() && noPinFields()
            && request.resource.data.score == resource.data.get('score', 0)
            && request.resource.data.keys().hasOnly(['score','ts','uid']));
      // 옛 닉네임 문서 정리(닉변)는 uid 소유자 본인/서버만
      allow delete: if isAdmin()
        || (signedIn() && ('uid' in resource.data) && resource.data.uid == request.auth.uid);
    }

    // weekly rankings — compat과 동일 (uid 관련 없음)
    // PR3: 주간 점수는 클라이언트가 쓸 정상 경로가 없음(게임종료 W1도 이제 submitScore CF 경유).
    //  → 클라 create/update 전면 차단, CF(Admin SDK)만 write. read는 공개 유지.
    match /weekly_rankings/{weekId}/scores/{nick} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin()
        || !exists(/databases/$(database)/documents/rankings/$(nick));
    }

    // user_stats — 젤리는 클라이언트가 절대 늘릴 수 없음 (증가는 서버 함수만)
    match /user_stats/{id} {
      allow read: if true;
      allow create: if isAdmin()
        || ((isUidDoc(id) || validNick(id)) && uidFieldOkCreate()
            && request.resource.data.get('jelly', 0) is int
            && request.resource.data.get('jelly', 0) >= 0
            && request.resource.data.get('jelly', 0) <= 10
            && (!('bestScore' in request.resource.data)
                || (request.resource.data.bestScore is int
                    && request.resource.data.bestScore >= 0
                    && request.resource.data.bestScore <= 150000)));
      allow update: if isAdmin()
        || (uidFieldOk()
            && request.resource.data.get('jelly', 0) is int
            && request.resource.data.get('jelly', 0) >= 0
            && request.resource.data.get('jelly', 0) <= resource.data.get('jelly', 0)
            && (!('bestScore' in request.resource.data)
                || (request.resource.data.bestScore is int
                    && request.resource.data.bestScore >= 0
                    && request.resource.data.bestScore <= 150000)));
      allow delete: if isAdmin();
    }

    // champions — compat과 동일
    match /champions/{nick} {
      allow read: if true;
      allow create: if isAdmin()
        || (validNick(nick)
            && request.resource.data.get('count', 0) == 1);
      allow update: if isAdmin()
        || (request.resource.data.get('count', 0) is int
            && request.resource.data.get('count', 0) >= resource.data.get('count', 0)
            && request.resource.data.get('count', 0) <= resource.data.get('count', 0) + 1);
      allow delete: if isAdmin();
    }

    // meta — compat과 동일
    function metaOk(docId) {
      return (docId == 'currentChampion'
                && request.resource.data.keys().hasOnly(['nickname','ts'])
                && okStr(request.resource.data.get('nickname', ''), 20))
        || (docId == 'weeklyCrownState'
                && request.resource.data.keys().hasOnly(['lastCrownedWeek'])
                && request.resource.data.lastCrownedWeek is string
                && request.resource.data.lastCrownedWeek.size() <= 12)
        || (docId == 'rankSnapshot'
                && request.resource.data.keys().hasOnly(['date','savedAt','ranks','v']))
        || (docId == 'weeklyRankSnapshot'
                && request.resource.data.keys().hasOnly(['date','savedAt','ranks','weekId']))
        || (docId == 'dailyNewUsers'
                && request.resource.data.keys().hasOnly(['date','savedAt','nicknames']));
    }
    match /meta/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() || metaOk(docId);
      allow delete: if isAdmin();
    }

    // nickname_skins — 소유권(cat/ownedSkins/bubblePurchased) 완전 잠금
    // + 장착(skin)은 무료거나 이미 소유한 것만, frame은 여전히 서버/어드민 전용
    function skinTextOk() {
      return okStr(request.resource.data.get('skin', null), 20)
        && okStr(request.resource.data.get('bubble', null), 10)
        && request.resource.data.get('ownedSkins', []) is list
        && request.resource.data.get('ownedSkins', []).size() <= 30;
    }
    // 신규 문서는 어떤 소유권도 갖고 태어날 수 없음
    function skinPrivilegesAbsent() {
      return request.resource.data.get('cat', false) == false
          && request.resource.data.get('ownedSkins', []) == []
          && request.resource.data.get('bubblePurchased', false) == false
          && request.resource.data.get('notifyPending', false) == false
          && request.resource.data.get('thanksPending', false) == false;
    }
    // 신규 문서의 장착 상태: skin은 없음/무료 컬러만, frame·bubble은 없음만
    // (bubble도 여기서 막아야 함 — 안 그러면 신규 문서를 만들면서 bubblePurchased:false와
    //  bubble:"문구"를 같이 넣어 구매 없이 말풍선을 표시하는 우회가 가능해짐)
    function equipSeedOk() {
      return (request.resource.data.get('skin', null) == null
           || request.resource.data.get('skin', '') == ''
           || request.resource.data.get('skin', '') in ['gold', 'pink', 'mint', 'purple', 'red', 'sky'])
          && request.resource.data.get('frame', null) == null
          && (request.resource.data.get('bubble', null) == null
              || request.resource.data.get('bubble', '') == '');
    }
    // cat·ownedSkins·bubblePurchased는 클라이언트가 절대 바꿀 수 없음(동일값만).
    // 지급 알림(notifyPending/thanksPending)은 끄기(true→false)만 클라이언트 허용.
    function skinPrivilegesUnchanged() {
      return request.resource.data.get('cat', false) == resource.data.get('cat', false)
          && request.resource.data.get('ownedSkins', []) == resource.data.get('ownedSkins', [])
          && request.resource.data.get('bubblePurchased', false) == resource.data.get('bubblePurchased', false)
          && (request.resource.data.get('notifyPending', false) != true
              || resource.data.get('notifyPending', false) == true)
          && (request.resource.data.get('thanksPending', false) != true
              || resource.data.get('thanksPending', false) == true);
    }
    // skin 장착: 기존값 유지 / 끄기 / 무료 컬러 6종 / 이미 소유한 것만 허용
    function skinEquipOk() {
      return request.resource.data.get('skin', null) == resource.data.get('skin', null)
          || request.resource.data.get('skin', null) == null
          || request.resource.data.get('skin', '') == ''
          || request.resource.data.get('skin', '') in ['gold', 'pink', 'mint', 'purple', 'red', 'sky']
          || request.resource.data.get('skin', '') in resource.data.get('ownedSkins', []);
    }
    // frame: 전부 유료(원화)이고 클라이언트가 쓸 일이 없음 — 기존값 유지만 허용
    function frameNotForged() {
      return request.resource.data.get('frame', null) == resource.data.get('frame', null);
    }
    // 말풍선 문구: bubblePurchased가 이미 true였던 경우에만 실제 문구를 넣을 수 있음.
    // 끄기(null/빈 문자열)는 구매 여부와 무관하게 항상 허용 — 20젤리 구매를
    // "bubblePurchased:false로 두고 bubble만 직접 쓰기"로 우회하는 걸 차단.
    function bubbleGuardOk() {
      return request.resource.data.get('bubble', null) == null
          || request.resource.data.get('bubble', '') == ''
          || resource.data.get('bubblePurchased', false) == true;
    }
    match /nickname_skins/{id} {
      allow read: if true;
      allow create: if isAdmin()
        || ((isUidDoc(id) || validNick(id)) && skinTextOk() && uidFieldOkCreate()
            && skinPrivilegesAbsent() && equipSeedOk());
      allow update: if isAdmin()
        || (skinTextOk() && uidFieldOk()
            && skinPrivilegesUnchanged() && skinEquipOk() && frameNotForged() && bubbleGuardOk());
      allow delete: if isAdmin();
    }

    // feedback — compat과 동일
    // feedback — 비밀글(1:1 문의). UI가 "개발자만 볼 수 있다"고 안내하므로
    // 실제 데이터 접근권한도 그와 일치해야 한다. uid로 연결된 사람만 자기 글을
    // 읽을 수 있고, 그 외엔 어드민(실제 Firebase Auth)만 전체를 볼 수 있다.
    // (닉네임은 인증과 무관한 자유 텍스트라 소유권 판별 기준으로 쓸 수 없음 —
    //  반드시 uid 기준이어야 하며, uid가 없는 레거시 제출 글은 본인도 재조회 불가.
    //  제출·관리자 답변 확인 자체는 그대로 되고, "내 글 목록/안읽음 확인" 기능만
    //  uid 연결된 사람 한정으로 동작한다.)
    // feedback — 비밀글. 아래 두 가지를 규칙 레벨에서 반드시 막는다(취약점 수정):
    //  ① 신규 작성 시 최초 메시지의 from을 'user' 외 다른 값으로 위조하는 것
    //  ② 본인 문서라는 이유로 messages 배열에 {from:'admin', ...}을 직접 끼워넣거나
    //     reply 필드를 직접 만들어서 "답변 완료"를 위조하는 것
    // → 실제 답장 이어쓰기는 서버 함수(appendFeedbackMessage, Admin SDK)만 하고,
    //    클라이언트의 update는 messages/reply/lastTs/adminUnread를 절대 바꿀 수 없다
    //    (내가 읽었다는 표시인 userUnread만 끌 수 있음).
    match /feedback/{docId} {
      allow read: if isAdmin() || isOwnerDevice()
        || (signedIn() && ('uid' in resource.data) && resource.data.uid == request.auth.uid);
      allow create: if request.resource.data.nickname is string
        && okStr(request.resource.data.nickname, 20)
        && request.resource.data.get('messages', []) is list
        && request.resource.data.get('messages', []).size() <= 1
        && (request.resource.data.get('messages', []).size() == 0
            || request.resource.data.messages[0].from == 'user')
        && !('reply' in request.resource.data)
        && (!('uid' in request.resource.data)
            || (signedIn() && request.resource.data.uid == request.auth.uid));
      // 일반 유저의 update는 diff().affectedKeys()로 "정확히 userUnread 하나만"
      // 바뀌었는지 확인한다 — 필드를 하나하나 나열해서 "그대로인지" 비교하던 예전 방식은
      // 새 필드(ts·type 등)가 늘어나면 빠뜨리기 쉬워서, 아예 "이 필드 외엔 어떤 변화도
      // 없어야 한다"는 방식으로 바꿈. uid·nickname·messages·reply·ts·lastTs·adminUnread·
      // type은 물론, 여기 없는 그 어떤 새 필드 추가/삭제/수정도 이 한 줄로 전부 막힌다.
      allow update: if isAdmin()
        || (signedIn() && ('uid' in resource.data) && resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userUnread']));
      allow delete: if isAdmin();
    }

    // feedback_donate — 입금자명 등 실명이 걸린 민감 정보. 일반 유저는 제출(create)만
    // 가능하고, 재조회·수정·삭제는 전부 실제 Firebase Auth 어드민만 가능.
    // (로컬스토리지 플래그는 어떤 경우에도 권한 근거로 쓰지 않음)
    match /feedback_donate/{docId} {
      // read: 어드민 · 오너(게임) · 본인(자기가 남긴 후원 쪽지+답장 열람). update는 본인의
      // userUnread(안읽음 표시) 해제만 허용 — 그 외 필드 위변조나 삭제는 어드민만.
      allow read: if isAdmin() || isOwnerDevice()
        || (signedIn() && ('uid' in resource.data) && resource.data.uid == request.auth.uid);
      allow update: if isAdmin()
        || (signedIn() && ('uid' in resource.data) && resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userUnread']));
      allow delete: if isAdmin();
      allow create: if request.resource.data.nickname is string
        && okStr(request.resource.data.nickname, 20)
        && request.resource.data.get('messages', []) is list
        && request.resource.data.get('messages', []).size() <= 1
        && (!('uid' in request.resource.data)
            || (signedIn() && request.resource.data.uid == request.auth.uid));
    }

    // feedback_public — 게시판 목록 표시 전용 공개 요약. 실제 비밀글(feedback)과
    // 완전히 분리된 별도 문서이며, 정확히 3개 필드(maskedNickname/ts/hasReply)만
    // 존재할 수 있다. uid·PIN·원본 닉네임·문의 내용·입금자명은 여기 절대 없음.
    // 클라이언트는 이 컬렉션에 절대 직접 쓸 수 없음 — 오직 서버 트리거
    // (Cloud Function, Admin SDK로 규칙 자체를 우회)만 생성·갱신 가능.
    // 그래서 "정확히 허용된 필드만" 요구사항은 클라이언트 write를 원천 차단하는
    // 것으로 가장 안전하게 만족된다(허용된 쓰기 경로 자체가 없음).
    match /feedback_public/{docId} {
      allow read: if true;
      allow create, update: if false;
      allow delete: if isAdmin();
    }

    // click logs — compat과 동일
    // tutorial_starts / jellyshop_clicks / supporterpack_clicks 는 안 쓰는 추적이라 규칙에서도 제거함
    // (아래 catch-all이 read/write 모두 차단 — 과거 문서는 남아있어도 더 이상 쓰지도 읽지도 않음)
    match /donate_clicks/{d}         { allow read: if true; allow create: if validLog(); }
    match /share_clicks/{d}          { allow read: if true; allow create: if validLog(); }
    // support_topbtn_clicks: 버튼 라벨은 "스킨샵"으로 바뀌었지만(응원하기 버튼 자체가 사라짐),
    // 클릭 이벤트 배선은 그대로라 컬렉션명은 유지 — admin 표시 라벨만 바뀜.
    match /support_topbtn_clicks/{d} { allow read: if true; allow create: if validLog(); }
    match /updatelog_clicks/{d}      { allow read: if true; allow create: if validLog(); }
    match /snack_clicks/{d}          { allow read: if true; allow create: if validLog(); }
    match /thanks_toggle_clicks/{d}  { allow read: if true; allow create: if validLog(); }
    // ⭐ 게임 리뷰 입구 버튼 클릭 (랭킹탭/메인 어디서 눌렀는지 source로 구분)
    match /review_entry_clicks/{d}   { allow read: if true; allow create: if validReviewClickLog(); }
    // 👤 내 정보 열람 기록 — 필드 구성이 리뷰 클릭과 동일(nickname/ts/date/source)이라 같은 검증 재사용
    match /myinfo_clicks/{d}         { allow read: if true; allow create: if validReviewClickLog(); }

    // ⭐ 리뷰 요청 카드 "본 사람" 기록 — 문서 id = uid. 사람당 1회 노출 판정 + 어드민 추적.
    //  본인만 자기 문서 생성/수정/조회. action: 노출('shown')·리뷰남기기('write')·그냥계속('dismiss').
    //  본인이 버튼을 누른 순간 자기 문서의 action만 갱신(setDoc 덮어쓰기). 삭제는 어드민만.
    function validPromptShown() {
      return request.resource.data.keys().hasOnly(['nickname','ts','date','action'])
        && okStr(request.resource.data.get('nickname', ''), 20)
        && request.resource.data.get('action', 'shown') in ['shown','write','dismiss'];
    }
    match /review_prompt_shown/{uid} {
      allow read:   if isAdmin() || isUidDoc(uid);
      allow create, update: if isAdmin() || (isUidDoc(uid) && validPromptShown());
      allow delete: if isAdmin();
    }

    // visit_sessions — compat과 동일
    match /visit_sessions/{sessionId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly(
          ['sessionId','visitorKey','nickname','date','enterTs','lastSeenTs','durationSec','playStarted','playCount'])
        && request.resource.data.sessionId is string
        && request.resource.data.visitorKey is string
        && okStr(request.resource.data.get('nickname', ''), 20)
        && request.resource.data.date is string
        && request.resource.data.enterTs is int
        && request.resource.data.lastSeenTs is int
        && request.resource.data.durationSec is int
        && request.resource.data.durationSec >= 0
        && request.resource.data.durationSec <= 7200
        && request.resource.data.playStarted is bool
        && request.resource.data.playCount is int
        && request.resource.data.playCount >= 0;
      allow delete: if isAdmin();
    }

    // skin_requests — compat과 동일
    match /skin_requests/{d} {
      allow read: if true;
      allow create: if request.resource.data.nickname is string
        && okStr(request.resource.data.nickname, 20)
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.price <= 1000000;
      allow update, delete: if isAdmin();
    }

    // ref_codes — compat과 동일
    match /ref_codes/{code} {
      allow read: if true;
      allow create: if code.size() <= 12
        && request.resource.data.keys().hasOnly(['nickname'])
        && request.resource.data.nickname is string
        && okStr(request.resource.data.nickname, 20);
      allow update: if isAdmin()
        || (request.resource.data.keys().hasOnly(['nickname'])
            && request.resource.data.nickname == resource.data.get('nickname', ''));
      allow delete: if isAdmin();
    }

    // ══════════════ 신규 컬렉션 — compat과 동일 ══════════════

    match /users/{uid} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == uid
        && okStr(request.resource.data.get('nickname', null), 20)
        && okStr(request.resource.data.get('nicknameNormalized', null), 20);
      allow delete: if false;
    }

    match /users_private/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow read, update, delete: if false;
    }

    match /nickname_lookup/{norm} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.nickname is string
        && !('claimedVia' in request.resource.data)
        && !exists(/databases/$(database)/documents/rankings/$(request.resource.data.nickname));
      allow update: if false;
      allow delete: if signedIn() && ('uid' in resource.data) && resource.data.uid == request.auth.uid;
    }

    match /legacy_account_secrets/{nick} {
      allow read, write: if false;
    }

    match /pin_attempts/{key} {
      allow read, write: if false;
    }

    match /account_config/{docId} {
      allow read, write: if false;
    }

    // ══════════════ 게임 리뷰 (앱스토어식 별점+한마디) ══════════════
    // 모든 쓰기는 reviewAction Cloud Function(Admin SDK, 규칙 우회)만.
    // 클라이언트 write 전면 차단 — 별점/하트/답글 위조, 남의 리뷰 수정 전부 불가.
    match /game_reviews/{uid} {
      allow read: if true;      // 공개 리뷰 목록
      allow write: if false;
    }
    // 보류함(욕설 필터 HOLD) — 공개 전이므로 어드민만 읽기 가능
    match /game_reviews_pending/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }
    // 통계 요약(평균/개수) — 입구 뱃지가 이 문서 1개만 읽음
    match /game_reviews_meta/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // game_sessions — 서버 세션 shadow telemetry (PR2) + 공식 판정(PR3).
    // write 는 오직 Cloud Function(Admin SDK, 규칙 우회)만. 클라이언트 write 절대 불가.
    // read 는 어드민(관리자 대시보드)만 허용 — 보류/거부된 판(official.decision)을
    // 관리자 알림 패널에서 조회하기 위함. 일반 유저는 인증 여부와 무관하게 read 불가.
    match /game_sessions/{sessionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ranking_blocklist — 랭킹 영구차단(섀도우밴) 명단. {uid} 문서가 있으면 그 계정의
    // 점수는 submitScore(Admin SDK)가 랭킹에 반영하지 않는다. 어드민만 읽고/쓰기.
    // 일반 클라이언트는 read 불가(자기가 차단됐는지 알 수 없어야 섀도우밴이 유지됨).
    match /ranking_blocklist/{uid} {
      allow read, write: if isAdmin();
    }

    // play_xp — 오잉 레벨 플레이 XP(정상 완료 판당 +1, KST 하루 상한 10).
    // write 는 오직 submitScore Cloud Function(Admin SDK, 규칙 우회)만 — 클라이언트가
    // XP를 위조/증가시킬 수 없음. read 는 공개(단순 활동 카운터라 민감정보 없음 — 내정보
    // 표시·기기 간 동기화용. user_stats 공개 read와 동일한 수준).
    match /play_xp/{uid} {
      allow read: if true;
      allow write: if false;
    }

    // 닉네임 변경 이력(서버 함수가 기록) — 어드민이 유저 상세에서 이전 닉네임을 확인하는 용도.
    // 일반 클라이언트는 읽기 불가(타인의 개명 이력은 비공개), 쓰기는 서버(Admin SDK)만.
    match /rename_history/{id} {
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
